{
    "name": "gawrys/counterparty-core",
    "description": "Framework-agnostic core for counterparty due diligence: domain model, ports, rule-based risk strategy, PSR-18 reference adapters and contract tests.",
    "license": "MIT",
    "type": "library",
    "keywords": ["due-diligence", "kyc", "sanctions", "vat", "white-list", "vies", "psr"],
    "authors": [
        {
            "name": "Igor Gawrys",
            "email": "igor@fikg.pl"
        }
    ],
    "require": {
        "php": ">=8.2",
        "psr/clock": "^1.0",
        "psr/http-client": "^1.0",
        "psr/http-client-implementation": "*",
        "psr/http-factory": "^1.0",
        "psr/http-factory-implementation": "*",
        "psr/http-message": "^1.1 || ^2.0",
        "psr/simple-cache": "^2.0 || ^3.0",
        "psr/log": "^2.0 || ^3.0",
        "php-http/discovery": "^1.19"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.64",
        "nyholm/psr7": "^1.8",
        "php-http/mock-client": "^1.6",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpunit/phpunit": "^11.0",
        "psalm/plugin-phpunit": "^0.19",
        "symfony/http-client": "^6.4 || ^7.0",
        "vimeo/psalm": "^6.0"
    },
    "autoload": {
        "psr-4": {
            "Gawrys\\Counterparty\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Gawrys\\Counterparty\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "check": ["@cs:check", "@stan", "@psalm", "@test"],
        "cs:check": "php-cs-fixer fix --dry-run --diff --ansi",
        "cs:fix": "php-cs-fixer fix --ansi",
        "stan": "phpstan analyse --ansi --memory-limit=1G",
        "psalm": "psalm --no-progress",
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
